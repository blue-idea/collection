{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:staged": "lint-staged --config ../config/lint-staged.mjs",
    "prepare": "cd .. && husky ui/.husky",
    "preview": "vite preview",
    "quality": "pnpm lint && pnpm typecheck && pnpm build",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:impact": "node ./scripts/select-e2e-tests.mjs",
    "test:e2e:impact:test": "node --test ./scripts/select-e2e-tests.test.mjs",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "supabase:start": "supabase start --workdir ..",
    "supabase:status": "supabase status --workdir ..",
    "supabase:reset": "supabase db reset --workdir ..",
    "supabase:types": "supabase gen types typescript --local --workdir .. > src/database.types.ts",
    "test:supabase": "supabase test db --workdir .. && node ./scripts/supabase-rls-api-test.mjs && node ./scripts/supabase-auth-api-test.mjs && node ./scripts/supabase-revision-api-test.mjs",
    "test:supabase:auth": "node ./scripts/supabase-auth-api-test.mjs",
    "test:supabase:revision": "node ./scripts/supabase-revision-api-test.mjs",
    "test:cloud:remote": "node ./scripts/cloud-remote-test.mjs",
    "test:security": "node --test ./scripts/test-env.test.mjs && node ./scripts/security-scan.mjs && vitest run src/features/import-export src/services/settings src/features/bookmarks src/features/categories src/services/storage src/repositories/cloud",
    "test:performance": "pnpm build && playwright test --config playwright.performance.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "verify:quality-config": "node verify-quality-config.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.57.4",
    "@tanstack/react-virtual": "^3.14.6",
    "i18next": "^26.3.6",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "4.0.1",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "husky": "9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "17.0.8",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "vite": "^6.4.3"
    }
  }
}
